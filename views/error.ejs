<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= locals.code %></title>
    <style>
        body {
            font-family: Arial, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            background-color: #f4f4f4;
            color: #333;
        }
        .container {
            text-align: center;
        }
        .error-code {
            font-size: 100px;
            font-weight: bold;
            color: red;
            margin: 0;
        }
        .error-message {
            font-size: 20px;
            margin-top: 10px;
        }
    </style>
</head>
<body>
    <div class="container">
        <p class="error-code"><%= locals.code %></p>
        <p class="error-message"><%= locals.text %></p>
    </div>
</body>
</html>
