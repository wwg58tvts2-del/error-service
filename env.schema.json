{
  "vars": [
    {
      "key": "APP_NAME",
      "type": "string",
      "default": "Default-Error",
      "description": "Name der Anwendung"
    },
    {
      "key": "SERVER_PORT",
      "type": "number",
      "default": 8087,
      "description": "Port auf dem der Service läuft"
    },
    {
      "key": "ERROR_CONFIG_PATH",
      "type": "string",
      "default": "error.json",
      "description": "Pfad zur JSON-Datei mit den Fehlermeldungs-Texten"
    },
    {
      "key": "AUTH_ON",
      "type": "boolean",
      "default": false,
      "description": "Aktiviert die JWT-Authentifizierung"
    },
    {
      "key": "AUTH_JWT_SECRET",
      "type": "secret",
      "default": "default-secret-change-in-production",
      "description": "Geheimer Schlüssel zur JWT-Signierung – unbedingt ändern!",
      "showIf": { "key": "AUTH_ON", "value": "true" }
    },
    {
      "key": "AUTH_URL",
      "type": "string",
      "default": "/auth",
      "description": "Pfad des Auth-Endpoints",
      "showIf": { "key": "AUTH_ON", "value": "true" }
    }
  ]
}
